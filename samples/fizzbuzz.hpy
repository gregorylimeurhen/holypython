function fizz(number)
{
	return number % 3 = 0
}

function buzz(number)
{
	return number % 5 = 0
}

function fizzbuzz(number)
{
	return number % 15 = 0
}

start <- 1
end <- 50
for number in [start..end]:
	if fizzbuzz(number):
		print("FizzBuzz")
	elif fizz(number):
		print("Fizz")
	elif buzz(number):
		print("Buzz")
	else:
		print(number)
